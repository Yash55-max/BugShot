{
  "manifest_version": 3,
  "name": "BugShot — Screenshot to Bug Report",
  "version": "3.1.0",
  "description": "Capture, annotate, and file bug reports to GitHub in one click.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "<all_urls>"
  ],
  "devtools_page": "devtools/devtools.html",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup/*", "content/*", "devtools/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
